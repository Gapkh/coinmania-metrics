# Copy this file to `.env` and fill in your values.
# DO NOT commit `.env` to git.

# --- Google Play ---
# Absolute path to the service account JSON file you downloaded.
GOOGLE_SA_JSON=/absolute/path/to/service-account.json

# Your app's package name (e.g. com.yourcompany.yourapp).
PLAY_PACKAGE_NAME=com.yourcompany.yourapp

# The pubsite GCS bucket where Play exports your daily CSV reports.
# Found in Play Console → Download reports → Statistics → bottom of page.
# Use the bucket name only, no gs:// prefix.
PLAY_GCS_BUCKET=pubsite_prod_rev_01234567890


# --- App Store Connect ---
# 10-character key identifier from App Store Connect → Users and Access → Keys.
ASC_KEY_ID=ABC123XYZ4

# UUID issuer ID from the same page.
ASC_ISSUER_ID=12a3b456-7890-1234-5678-1234567890ab

# Absolute path to the AuthKey_XXXX.p8 file you downloaded.
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_ABC123XYZ4.p8

# Numeric vendor number from App Store Connect.
ASC_VENDOR_NUMBER=12345678

# Numeric app ID (from the App Store Connect URL of your app).
ASC_APP_ID=1234567890
